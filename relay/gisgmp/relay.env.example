# relay/gisgmp/relay.env  — конфиг релея ГИС ГМП → ЖКХ.
# Скопируй в /opt/gisgmp-relay/relay.env на машине релея (aleks) и заполни.
# Файл с паролем — chmod 600!

# Корп-вход в реестр (passport.cgu.mchs.ru), логин/пароль:
PASSPORT_USERNAME=Иваницкий К.В.
PASSPORT_PASSWORD=ЗАМЕНИ_НА_ПАРОЛЬ

# Куда слать долги и токен (тот же, что GISGMP_SYNC_TOKEN в .env ЖКХ):
JKH_URL=https://asy-tk.ru
GISGMP_SYNC_TOKEN=ЗАМЕНИ_НА_ТОКЕН

# Подпись само-обновления (RCE-защита #19). ОТДЕЛЬНЫЙ ключ — НЕ равен
# GISGMP_SYNC_TOKEN (тот летит в каждом запросе, виден MITM). По сети не ходит.
# То же значение задать в .env ЖКХ как RELAY_UPDATE_SECRET. Пока пусто на обоих
# концах — обновление работает без проверки (обратная совместимость).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
RELAY_UPDATE_SECRET=ЗАМЕНИ_НА_КЛЮЧ_ПОДПИСИ

# Сколько страниц реестра читать максимум (защита от бесконечного обхода).
MAX_PAGES=200
# 1 = читать только «Не сквитировано» (быстрее, только долги; но оплативших
# обнулит лишь при следующем полном проходе). 0 = читать все (рекомендуется).
ONLY_UNPAID=0

# ─── 1С (БГУ) авто-подгрузка ОСВ (тот же демон, headless-браузер Playwright) ───
# Логин/пароль 1С задаются в UI ЖКХ («Долги 1С» → карточка «Авто-подгрузка из
# 1С») и приходят релею автоматически (шифрованно), он пишет их в onec.env ниже.
# Здесь их задавать НЕ обязательно. ONEC_ENV_FILE/ONEC_PROBE_DIR — пути на ВМ.
ONEC_ENV_FILE=/opt/gisgmp-relay/onec.env
ONEC_PROBE_DIR=/opt/gisgmp-relay/onec_probe
# Опционально (если не хочешь вводить в UI):
# ONEC_LOGIN=Пользователь 1С
# ONEC_PASSWORD=пароль_1С
