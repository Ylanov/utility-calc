# relay/gisgmp/relay.env  — конфиг релея ГИС ГМП → ЖКХ.
# Скопируй в /opt/gisgmp-relay/relay.env на ВМ PODS2 и заполни.
# Файл с паролем — chmod 600!

# Корп-вход в реестр (passport.cgu.mchs.ru), логин/пароль:
PASSPORT_USERNAME=Иваницкий К.В.
PASSPORT_PASSWORD=ЗАМЕНИ_НА_ПАРОЛЬ

# Куда слать долги и токен (тот же, что GISGMP_SYNC_TOKEN в .env ЖКХ):
JKH_URL=https://asy-tk.ru
GISGMP_SYNC_TOKEN=vyVOIN4J4qEC4n2_-Poyf4hAKCyhBr76eFwAHBJaB_g

# Сколько страниц реестра читать максимум (защита от бесконечного обхода).
MAX_PAGES=200
# 1 = читать только «Не сквитировано» (быстрее, только долги; но оплативших
# обнулит лишь при следующем полном проходе). 0 = читать все (рекомендуется).
ONLY_UNPAID=0
