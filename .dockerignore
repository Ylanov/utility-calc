# .gitignore (дополнение — добавь эти строки в свой .gitignore)

# ==========================================
# СЕКРЕТЫ И ОКРУЖЕНИЯ
# ==========================================
.env
.env.local
.env.production
.env.*
!.env.local     # .env.local — шаблон, его можно коммитить (без реальных секретов)

# ==========================================
# ЛОКАЛЬНЫЕ ДАННЫЕ
# ==========================================
backups/
static/generated_files/
static/temp_imports/

# ==========================================
# СБОРКА И КЕШ
# ==========================================
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
.trivy-cache/
trivy-report.json

# ==========================================
# IDE
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# СЕРТИФИКАТЫ (генерируются на сервере)
# ==========================================
ssl/
*.pem
*.key
*.crt
